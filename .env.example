# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=splito
POSTGRES_PASSWORD=splito_secret
POSTGRES_DB=splito_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://splito:splito_secret@db:5432/splito_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
APP_NAME=Splito
API_VERSION=v1
